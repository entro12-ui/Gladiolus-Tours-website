{
  "name": "ui-page-destinations",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "modules/ui-page-destinations/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "modules/ui-page-destinations/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/modules/ui-page-destinations",
        "tsConfig": "modules/ui-page-destinations/tsconfig.lib.json",
        "project": "modules/ui-page-destinations/package.json",
        "entryFile": "modules/ui-page-destinations/src/index.ts",
        "external": ["react", "react-dom", "react/jsx-runtime"],
        "rollupConfig": "@nx/react/plugins/bundle-rollup",
        "compiler": "babel",
        "assets": [
          {
            "glob": "modules/ui-page-destinations/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "modules/ui-page-destinations/jest.config.ts"
      }
    }
  }
}
