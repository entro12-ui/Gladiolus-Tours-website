        "modules/ui-comp-page-helmet/src/index.ts"
      ],
      "@gladiolus/ui-comp-router-lazy-fallback": [
        "modules/ui-comp-router-lazy-fallback/src/index.ts"
      ],
      "@gladiolus/ui-comp-scroll-to-top": [
        "modules/ui-comp-scroll-to-top/src/index.ts"
      ],
      "@gladiolus/ui-layout-gladiolus": [
        "modules/ui-layout-gladiolus/src/index.ts"
      ],
      "@gladiolus/ui-page-about-us": ["modules/ui-page-about-us/src/index.ts"],
      "@gladiolus/ui-page-accomodations": [
        "modules/ui-page-accomodations/src/index.ts"
      ],
      "@gladiolus/ui-page-contact": ["modules/ui-page-contact/src/index.ts"],
