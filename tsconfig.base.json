{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@gladiolus/ui-comp-router-lazy-fallback": [
        "modules/ui-comp-router-lazy-fallback/src/index.ts"
      ],
      "@gladiolus/ui-layout-gladiolus": [
        "modules/ui-layout-gladiolus/src/index.ts"
      ],
      "@gladiolus/ui-page-gladiolus-tours-error-404": [
        "modules/ui-page-gladiolus-tours-error-404/src/index.ts"
      ],
      "@gladiolus/ui-router-gladiolus": [
        "modules/ui-router-gladiolus/src/index.ts"
      ],
      "@gladiolus/ui-routes-gladiolus": [
        "modules/ui-routes-gladiolus/src/index.ts"
      ],
      "@gladiolus/ui-utils": ["modules/ui-utils/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
